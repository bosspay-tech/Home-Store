# ── BossPay Bridge ──────────────────────────────────────────────────
# Secret shared with BossPay (they provide this)
BOSSPAY_BRIDGE_SECRET=

# Public HTTPS URL where the site is reachable (no trailing slash)
# e.g. https://www.hairportcollections.com
BRIDGE_BASE_URL=

# Optional — defaults to https://api.bosspay24.com
# BOSSPAY_API_BASE=https://api.bosspay24.com

# ── Supabase (server-side, service role) ────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── SabPaisa credentials ────────────────────────────────────────────
# All five are SERVER-ONLY. Do NOT expose any of these to the browser
# (i.e. never prefix with VITE_). Payment init + response decryption are
# performed server-side; the React frontend only calls the bridge.
SABPAISA_CLIENT_CODE=
SABPAISA_USERNAME=
SABPAISA_PASSWORD=

# AuthKey: base64 string that decodes to EXACTLY 32 bytes (AES-256 key).
SABPAISA_AUTH_KEY=

# AuthIV: base64 string of any non-zero length. This is the HMAC-SHA384
# key, NOT a cipher IV. The GCM nonce is derived from the AuthKey.
SABPAISA_AUTH_IV=

# Informational only — the bridge always talks to SabPaisa production
# (securepay.sabpaisa.in / txnenquiry.sabpaisa.in). Keep as 'prod'.
SABPAISA_ENV=prod

# ── Callback-miss reconciler ────────────────────────────────────────
# Every ~15s, polls SabPaisa's TxnEnquiry API for bridge transactions
# from the last 15 minutes whose webhook has not yet been forwarded to
# BossPay, and synthesises a webhook on terminal status. Idempotent vs.
# the real callback path. Set to 0 to disable in emergencies.
SABPAISA_RECONCILER_ENABLED=1

# ── Server ──────────────────────────────────────────────────────────
PORT=3000

# ── Vite build args (for Docker build) ──────────────────────────────
# Only the Supabase anon-key surface is public by design. Do NOT add
# VITE_SABPAISA_* here — those would leak credentials into the browser
# bundle. Payment init goes through the bridge's server-side endpoints.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
