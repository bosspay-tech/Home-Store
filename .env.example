# Copy to .env and fill in values (Vite reads these at dev/build startup).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Comma-separated admin emails allowed to access /admin (must match signed-in account).
# Alternatively set user_metadata.is_admin = true in Supabase Auth for a user.
VITE_ADMIN_EMAILS=you@example.com

# Dev only — email that skips OTP (must match bridge TESTE). Leave empty in production.
VITE_TESTE=testvp@gmail.com
